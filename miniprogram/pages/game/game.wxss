/* 轮椅大作战 - 游戏页面样式 */

.game-container {
  width: 100%;
  height: 100%;
  position: relative;
  background-color: #333366;
}

/* HUD 叠加层 */
.hud-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hud-overlay view {
  pointer-events: auto;
}

/* 顶部状态栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.5), transparent);
}

/* 敌方信息 */
.enemy-info {
  flex: 1;
}

.player-name {
  font-size: 26rpx;
  color: #FF6666;
  margin-bottom: 10rpx;
}

.health-bar {
  width: 200rpx;
  height: 16rpx;
  background-color: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  overflow: hidden;
}

.health-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF3333, #FF6666);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 倒计时 */
.timer {
  flex: 1;
  display: flex;
  justify-content: center;
}

.timer-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 2rpx 10rpx rgba(255,215,0,0.5);
}

/* 暂停按钮 */
.pause-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background-color: rgba(255,255,255,0.2);
  border-radius: 50%;
}

/* 底部控制区 */
.control-area {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 40rpx 60rpx;
}

/* 虚拟摇杆 */
.joystick-area {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.joystick-base {
  width: 200rpx;
  height: 200rpx;
  background-color: rgba(255,255,255,0.15);
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.joystick-stick {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  border-radius: 50%;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.3);
  transition: transform 0.1s ease;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

/* 攻击按钮 */
.attack-btn {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #FF6666, #FF9966);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(255,102,102,0.4);
}

.attack-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.attack-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 技能按钮 */
.skill-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #666666, #888888);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.skill-btn.ready {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.skill-icon {
  font-size: 36rpx;
  z-index: 1;
}

.skill-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
}

.skill-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #FFD700;
  transition: height 0.1s linear;
}

/* 加载中 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #333366;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-bottom: 40rpx;
}

.loading-spinner {
  font-size: 80rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 暂停菜单 */
.pause-menu {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pause-title {
  font-size: 48rpx;
  color: #FFD700;
  margin-bottom: 60rpx;
}

.pause-menu .btn {
  margin: 20rpx 0;
}

/* 结算界面 */
.result-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-panel {
  width: 600rpx;
  background-color: #444466;
  border-radius: 30rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-title {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.result-title.win {
  color: #FFD700;
}

.result-title.lose {
  color: #AAAAAA;
}

.result-stats {
  width: 100%;
  margin-bottom: 30rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  color: #CCCCCC;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.rewards {
  display: flex;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.reward-item {
  font-size: 32rpx;
  color: #FFD700;
}

.result-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-buttons .btn {
  margin: 0;
}