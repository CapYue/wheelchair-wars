<!-- 轮椅大作战 - 设置页面 -->

<view class="container">
  <view class="header">
    <text class="title">⚙️ 设置</text>
  </view>

  <view class="settings-list">
    <!-- 音量设置 -->
    <view class="setting-item">
      <text class="setting-label">音效音量</text>
      <slider class="setting-slider" 
              min="0" max="100" 
              value="{{sfxVolume}}" 
              bindchange="onSFXVolumeChange" />
      <text class="setting-value">{{sfxVolume}}%</text>
    </view>

    <view class="setting-item">
      <text class="setting-label">音乐音量</text>
      <slider class="setting-slider" 
              min="0" max="100" 
              value="{{bgmVolume}}" 
              bindchange="onBGMVolumeChange" />
      <text class="setting-value">{{bgmVolume}}%</text>
    </view>

    <!-- 功能开关 -->
    <view class="setting-item switch">
      <text class="setting-label">振动反馈</text>
      <switch checked="{{vibration}}" bindchange="onVibrationChange" />
    </view>

    <view class="setting-item switch">
      <text class="setting-label">显示帧率</text>
      <switch checked="{{showFPS}}" bindchange="onShowFPSChange" />
    </view>

    <!-- 游戏画质 -->
    <view class="setting-item">
      <text class="setting-label">游戏画质</text>
      <picker mode="selector" 
              range="{{qualityOptions}}" 
              value="{{qualityIndex}}"
              bindchange="onQualityChange">
        <view class="picker-value">{{quality}}</view>
      </picker>
    </view>

    <!-- 控制方式 -->
    <view class="setting-item">
      <text class="setting-label">操控方式</text>
      <picker mode="selector" 
              range="{{controlOptions}}" 
              value="{{controlIndex}}"
              bindchange="onControlChange">
        <view class="picker-value">{{controlType}}</view>
      </picker>
    </view>
  </view>

  <!-- 账号信息 -->
  <view class="section">
    <view class="section-title">账号</view>
    <view class="account-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default_avatar.png'}}" />
      <view class="info">
        <text class="name">{{userInfo.nickName || '轮椅战士'}}</text>
        <text class="uid">ID: {{openid || '未登录'}}</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-title">关于</view>
    <view class="about-list">
      <view class="about-item" bindtap="onCheckUpdate">
        <text>检查更新</text>
        <text class="arrow">></text>
      </view>
      <view class="about-item" bindtap="onPrivacy">
        <text>隐私政策</text>
        <text class="arrow">></text>
      </view>
      <view class="about-item" bindtap="onTerms">
        <text>用户协议</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="version">轮椅大作战 v1.0.0</text>
    <text class="copyright">© 2024 Wheelchair Wars</text>
  </view>
</view>