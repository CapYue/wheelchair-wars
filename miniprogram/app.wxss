/* 轮椅大作战 - 全局样式 */

page {
  background-color: #333366;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 容器 */
.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 标题 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  text-align: center;
  margin: 30rpx 0;
}

/* 副标题 */
.subtitle {
  font-size: 28rpx;
  color: #CCCCCC;
  text-align: center;
  margin: 20rpx 0;
}

/* 按钮样式 */
.btn {
  width: 600rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6666, #FF9966);
  border: none;
  border-radius: 50rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(255, 102, 102, 0.3);
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background: linear-gradient(135deg, #6699FF, #66CCFF);
}

.btn-gold {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

/* 卡片 */
.card {
  width: 700rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
}

/* 列表项 */
.list-item {
  width: 100%;
  height: 120rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 15rpx;
  margin: 10rpx 0;
}

.list-item:active {
  background-color: rgba(255, 255, 255, 0.1);
}

/* 图标 */
.icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 5rpx 15rpx;
  background-color: #FFD700;
  color: #333;
  border-radius: 10rpx;
  font-size: 22rpx;
}

/* 进度条 */
.progress {
  width: 100%;
  height: 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #66CC33, #99FF66);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

/* 分割线 */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.1);
  margin: 20rpx 0;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #444466;
  border-radius: 20rpx;
  padding: 40rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 50rpx;
  color: #888888;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

/* 货币显示 */
.currency {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #FFD700;
  padding: 10rpx 20rpx;
  background-color: rgba(255, 215, 0, 0.1);
  border-radius: 20rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #FFD700;
}

/* 徽章 */
.badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #FFD700;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 20rpx;
  font-weight: bold;
}